{
    "workbench.editorAssociations": {
        "*.pdb": "default",
        "*.iso": "default",
        "*.bin": "default",
        "*.dat": "default"
    },
    "workbench.colorTheme": "Aura Dark (Soft Text)",
    "workbench.iconTheme": "vscode-jetbrains-icon-theme-2023-dark",
    "workbench.editor.empty.hint": "hidden",
    "editor.unicodeHighlight.nonBasicASCII": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "security.workspace.trust.untrustedFiles": "open",
    "editor.cursorBlinking": "phase",
    "workbench.list.smoothScrolling": true,
    "terminal.integrated.smoothScrolling": true,
    "editor.smoothScrolling": true,
    "editor.renderLineHighlight": "gutter",
    "editor.fontFamily": "JetBrainsMono Nerd Font",
    "editor.fontLigatures":  "'zero', 'cv01'",

//window-preferences
    "window.titleBarStyle": "custom", //native
    "apc.electron": {
        "titleBarStyle": "hiddenInset",
        "opacity": 1,
    },
//editor-preferences
    "workbench.startupEditor": "none",
    "workbench.tips.enabled": false,
    "window.zoomLevel": -0.4,
    "editor.fontSize": 15,
    "editor.tabSize": 2,
    "editor.lineHeight": 1.6,
    "editor.cursorWidth": 3,

// Background-preferences
    "background.enabled": true,
    "background.fullscreen": {
        "useFront": false,
        "style": {
            "background-position": "100% 100%",
            "background-size": "auto",
            "opacity": 0.9
        },
        "styles": [{}, {}, {}],
        // Local images can be dragged into the browser to quickly get the file protocol address from the address bar
        "images": ["file:///home/koki/.vscode/kxki/assets/vsc-bg/dark-forest-bg.jpg","file:///home/koki/.vscode/kxki/assets/vsc-bg/dark-forest-bg2.jpg"],
        "interval": 3600,
        "random": true
    },

//apc-preferences
    "animations.Install-Method": "Custom CSS and JS",
    "apc.imports": [
        "file:///home/koki/.vscode/extensions/brandonkirbyson.vscode-animations-2.0.7/dist/updateHandler.js"
    ],
        "vscode_custom_css.imports": [
            "file:///home/koki/.vscode/extensions/brandonkirbyson.vscode-animations-2.0.7/dist/updateHandler.js",
            "file:////home/koki/.vscode/extensions/gental.smoothui-1.1.3/css.css",
            "file:////home/koki/.vscode/extensions/gental.smoothui-1.1.3/js.js"
        ],
//animations-preferences
    "animations.Enabled": true,
    "animations.Scrolling": "Fade",
    "animations.CursorAnimation": true,
    "animations.UseCursorColorForCursorAnimation": true,
    "editor.cursorSmoothCaretAnimation": "on",

//indent-rainbow-preferences
    "indentRainbow.indicatorStyle": "light",
    "indentRainbow.lightIndicatorStyleLineWidth": 1,
    "indentRainbow.colors": [
        "rgba(150,150,240,0.4)",
        "rgba(165,165,165,0.4)"
    ],
    "indentRainbow.errorColor": "rgba(128,32,32,0.4)",
//user-json-end
    "breadcrumbs.enabled": false,
    "remoteHub.commitDirectlyWarning": "off",
    "git.autofetch": true,
    "discord.removeDetails": true,
}